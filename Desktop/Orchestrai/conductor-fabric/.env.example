# Conductor Fabric — Environment Configuration
# Copy to .env and customize for your deployment

# ──────────────────────────────────────────────
# Infrastructure
# ──────────────────────────────────────────────

CONDUCTOR_POSTGRES_DB=conductor
CONDUCTOR_POSTGRES_USER=conductor
CONDUCTOR_POSTGRES_PASSWORD=conductor
CONDUCTOR_POSTGRES_PORT=5432

CONDUCTOR_VALKEY_PASSWORD=
CONDUCTOR_VALKEY_PORT=6379

CONDUCTOR_CLICKHOUSE_USER=default
CONDUCTOR_CLICKHOUSE_PASSWORD=
CONDUCTOR_CLICKHOUSE_PORT=9000
CONDUCTOR_CLICKHOUSE_HTTP_PORT=8123

# ──────────────────────────────────────────────
# Conductor Fabric Ports
# ──────────────────────────────────────────────

CONDUCTOR_GATEWAY_PORT=8080
CONDUCTOR_CONDUCTOR_PORT=9090
CONDUCTOR_RUNTIME_PORT=7070

# ──────────────────────────────────────────────
# HuggingFace (required to download gated models)
# ──────────────────────────────────────────────

HF_TOKEN=

# ──────────────────────────────────────────────
# Test Environment
# ──────────────────────────────────────────────

TEST_ENV=dev
BASE_URL=http://localhost:8080
API_URL=http://localhost:8080/v1
CLICKHOUSE_URL=http://localhost:8123
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/conductor
VALKEY_URL=redis://localhost:6379

# ──────────────────────────────────────────────
# Performance test targets
# ──────────────────────────────────────────────

PERF_TARGET_RPS=100
PERF_DURATION=30s
PERF_TTFT_THRESHOLD_MS=500
PERF_P95_THRESHOLD_MS=30000
